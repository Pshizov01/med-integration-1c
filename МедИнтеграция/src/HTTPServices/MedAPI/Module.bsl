Функция OrderByIdGET(Запрос)
	
	Попытка
		ИД = Запрос.ПараметрыURL["id"];
		Заказ = Документы.ЗаказУслуги.НайтиПоНомеру(ИД);
		Если Заказ.Пустая() Тогда
    		Возврат ОтветОшибки(404, "not_found", "Заказ не найден");
		КонецЕсли;
		
		Услуги = Новый Массив;
		Для каждого Стр из Заказ.Услуги Цикл
			Эл = Новый Структура;
			Эл.Вставить("name",     Строка(Стр.Услуга));
		    Эл.Вставить("quantity", Стр.Количество);
		    Эл.Вставить("price",    Стр.Цена);
		    Эл.Вставить("sum",      Стр.Сумма);
		    Услуги.Добавить(Эл);
		КонецЦикла;
		
		Данные = Новый Структура;
		Данные.Вставить("id",       Заказ.Номер);
		Данные.Вставить("date",     Формат(Заказ.Дата, "ДФ=yyyy-MM-dd"));
		Данные.Вставить("patient",  Строка(Заказ.Пациент));
		Данные.Вставить("clinic",   Строка(Заказ.Клиника));
		Данные.Вставить("status",   Строка(Заказ.Статус));
		Данные.Вставить("comment",  Заказ.Комментарий);
		Данные.Вставить("services", Услуги);
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(ВСтрокуJSON(Данные));
		Возврат Ответ;
		
	Исключение
		Ответ = ОтветОшибки(500, "internal_error" , ОписаниеОшибки());
		Возврат Ответ;
	КонецПопытки;
		
		
		
	
КонецФункции

